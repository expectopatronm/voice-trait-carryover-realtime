digraph VoiceTraitCarryover {
  graph [
    rankdir=TB,
    bgcolor="#050505",
    pad="0.35",
    nodesep="0.65",
    ranksep="0.72",
    splines=ortho,
    outputorder=edgesfirst
  ];

  node [
    shape=box,
    style="rounded,filled",
    color="#f5f5f5",
    fillcolor="#111111",
    fontcolor="#f5f5f5",
    fontname="Segoe UI",
    fontsize=20,
    penwidth=2.0,
    margin="0.18,0.12"
  ];

  edge [
    color="#f5f5f5",
    fontcolor="#f5f5f5",
    fontname="Segoe UI",
    fontsize=16,
    penwidth=2.0,
    arrowsize=0.8
  ];

  title [
    shape=plain,
    margin=0,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD><FONT POINT-SIZE="31"><B>Voice Trait Carryover at a Tool Boundary</B></FONT></TD></TR>
      </TABLE>
    >
  ];

  user [
    width=4.6,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD><B>Latest spoken user turn</B></TD></TR>
      </TABLE>
    >
  ];

  extract [
    width=6.2,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD>Extract response-relevant speech traits</TD></TR>
        <TR><TD><FONT POINT-SIZE="15">language, register, affect, prosody, tempo, articulation</FONT></TD></TR>
      </TABLE>
    >
  ];

  needs_tool [
    shape=diamond,
    width=3.4,
    height=1.55,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD>Does the answer need</TD></TR>
        <TR><TD>a domain tool?</TD></TR>
      </TABLE>
    >
  ];

  direct [
    width=4.5,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>Direct answer</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="15">Use the extracted traits immediately</FONT></TD></TR>
      </TABLE>
    >
  ];

  carry [
    width=4.7,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>Ancillary carryover tool</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">store_voice_traits_summary_and_response(...)</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">arguments preserve trait state</FONT></TD></TR>
      </TABLE>
    >
  ];

  domain [
    width=4.1,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>Domain tools</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">weather, search, navigation,</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">messages, etc.</FONT></TD></TR>
      </TABLE>
    >
  ];

  echo [
    width=4.7,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>No-op protocol echo</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="14">same normalized summary dictionary</FONT></TD></TR>
      </TABLE>
    >
  ];

  final [
    width=7.0,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD><B>Final spoken answer preserves speech adaptation</B></TD></TR>
      </TABLE>
    >
  ];

  note [
    shape=plain,
    margin=0,
    label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD><FONT POINT-SIZE="14" COLOR="#bdbdbd">The semantic tool result and the speech-adaptive response plan meet again before the final answer.</FONT></TD></TR>
      </TABLE>
    >
  ];

  { rank=same; direct; carry; domain; }

  title -> user [style=invis, weight=10];
  user -> extract;
  extract -> needs_tool;
  needs_tool -> direct [label="No", tailport=sw, headport=n];
  needs_tool -> carry [label="Yes", tailport=s, headport=n];
  needs_tool -> domain [tailport=se, headport=n];
  carry -> echo;
  direct -> final [tailport=s, headport=nw];
  echo -> final [tailport=s, headport=n];
  domain -> final [tailport=s, headport=ne];
  final -> note [style=invis, weight=10];
}
